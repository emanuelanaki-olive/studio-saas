# Database (PostgreSQL — works with Supabase, Neon, RDS, or local Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/studio_saas?schema=public"

# Supabase Auth — find these in your Supabase project's
# Settings -> API page (https://supabase.com/dashboard/project/_/settings/api)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# SERVICE ROLE KEY: full admin access, bypasses Row Level Security.
# Used ONLY server-side (src/lib/supabase-admin.ts) during studio
# signup. NEVER expose this to the browser or commit it anywhere.
SUPABASE_SERVICE_ROLE_KEY=""

