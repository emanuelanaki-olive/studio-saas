// =============================================================
// Prisma Schema — Multi-Tenant Studio SaaS Platform
// =============================================================
// Tenancy model: SINGLE DATABASE, SHARED SCHEMA.
// Every tenant-scoped table carries a `studioId` foreign key.
// All application queries MUST filter by studioId (enforced in
// src/lib/db.ts via a Prisma Client Extension — see that file).
//
// Two parallel booking tracks:
//   Track A (Class/Booking)         — fixed-schedule group classes
//   Track B (Service/AvailabilityBlock/Appointment) — 1-on-1, on-demand
// Both follow the identical studioId-scoping + credit/membership
// pattern; see src/lib/bookings.ts and src/lib/appointments.ts.
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -------------------------------------------------------------
// ENUMS
// -------------------------------------------------------------

enum StudioStatus {
  active
  suspended
}

enum UserRole {
  super_admin // Anthropic-style platform admin, not tied to a single studio
  owner // Studio owner (renamed from "בעלים")
  staff // Studio staff / instructor (renamed from "צוות")
  client // End customer (renamed from "לקוח")
}

enum BookingStatus {
  booked
  cancelled // cancelled within the allowed window — credit refunded
  late_cancelled // cancelled inside the cancellation window — credit NOT refunded
  no_show // never cancelled, never showed up — credit NOT refunded
  waitlist
  attended // used by attendance tracking
}

enum MembershipType {
  monthly_unlimited // unlimited classes until expires_at
  monthly_limited // capped number of classes per period, resets monthly
  punch_card // fixed pool of credits, decremented per booking, no reset
}

enum MembershipStatus {
  active
  expired
  cancelled
  frozen // paused: expiresAt does not advance while frozen
}

enum ClientStatus {
  lead // inquired but never converted to a paying client
  active
  inactive // no active membership / hasn't attended recently
  frozen // membership frozen — kept distinct from MembershipStatus.frozen
         // because a client can have a frozen *account* independent of
         // any specific membership row (e.g. injury leave)
}

enum AppointmentStatus {
  booked
  cancelled
  late_cancelled
  no_show
  completed
}

// -------------------------------------------------------------
// LEADS MODULE
// -------------------------------------------------------------

enum LeadStatus {
  new // just came in, no contact yet
  contacted // staff reached out
  meeting_scheduled // a sales/intro meeting is booked
  trial_scheduled // a trial class/session is booked
  converted // became a paying client (linked via Lead.convertedUserId)
  lost // did not convert — see LeadLostReason for why
}

// Follow-up task type. Kept as a simple enum rather than a studio
// picklist since the practical task types are stable across studios
// (mirrors the "follow up" task seen in Arbox's task list).
enum LeadTaskType {
  follow_up
  call
  meeting
  other
}

// -------------------------------------------------------------
// TENANT ROOT
// -------------------------------------------------------------

model Studio {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  slug      String       @unique // used for path-based tenant resolution: /[studio_slug]
  status    StudioStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  // Relations
  users              User[]
  classes            Class[]
  bookings           Booking[]
  memberships        Membership[]
  settings           StudioSettings?
  services           Service[]
  appointments       Appointment[]
  leadSources        LeadSource[]
  leadLostReasons    LeadLostReason[]
  leads              Lead[]
  leadTasks          LeadTask[]
  availabilityBlocks AvailabilityBlock[]

  @@map("studios")
}

// -------------------------------------------------------------
// STUDIO SETTINGS (1:1 with Studio — operational policy config)
// -------------------------------------------------------------

model StudioSettings {
  id                       String   @id @default(uuid()) @db.Uuid
  studioId                 String   @unique @map("studio_id") @db.Uuid
  // How many hours before a class/appointment start time a client
  // can still cancel WITHOUT losing their credit. Cancelling inside
  // this window -> status becomes late_cancelled, credit not refunded.
  cancellationWindowHours  Int      @default(12) @map("cancellation_window_hours")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)

  @@map("studio_settings")
}

// -------------------------------------------------------------
// USERS (tenant-scoped, except super_admin which has studioId = null)
// -------------------------------------------------------------

model User {
  // NOTE: this id is NOT self-generated in practice — it is always
  // set explicitly to match the corresponding Supabase auth.users.id
  // (see src/app/api/studios/route.ts and src/app/signup/actions.ts).
  // The @default(uuid()) below only kicks in for rows created without
  // an explicit id (e.g. ad-hoc scripts/tests) — production signup
  // flows always pass id themselves.
  id        String   @id @default(uuid()) @db.Uuid
  studioId  String?  @map("studio_id") @db.Uuid // nullable ONLY for super_admin
  email     String
  fullName  String   @map("full_name")
  phone     String?
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // --- CRM fields (clients only, but harmless on staff/owner rows) ---
  // `status` tracks the CLIENT'S lifecycle independent of any single
  // membership row — e.g. a "lead" has no membership yet at all.
  clientStatus      ClientStatus? @map("client_status")
  healthDeclaration Boolean       @default(false) @map("health_declaration")
  medicalNotes      String?       @map("medical_notes")
  birthDate         DateTime?     @map("birth_date") @db.Date

  studio Studio? @relation(fields: [studioId], references: [id], onDelete: Cascade)

  // As an instructor on classes
  classesTaught Class[] @relation("Instructor")

  // As a client making bookings
  bookings    Booking[]    @relation("ClientBookings")
  memberships Membership[] @relation("ClientMemberships")

  // Appointments: as the client booking one, or as the staff member
  // providing it
  appointmentsAsClient   Appointment[]       @relation("AppointmentClient")
  appointmentsAsProvider Appointment[]       @relation("AppointmentProvider")
  availabilityBlocks     AvailabilityBlock[] @relation("ProviderAvailability")

  // Leads: as the staff member a lead is assigned to, as the user a
  // lead converted into, or as the staff member assigned a follow-up task
  leadsAssigned     Lead[]     @relation("LeadAssignee")
  convertedFromLead Lead[]     @relation("LeadConvertedUser")
  leadTasksAssigned LeadTask[] @relation("LeadTaskAssignee")

  // A user's email must be unique WITHIN a studio, not globally —
  // the same person (by email) could in theory be a client of two
  // different studios with two separate user rows.
  @@unique([studioId, email])
  @@index([studioId])
  @@map("users")
}

// -------------------------------------------------------------
// CLASSES / SCHEDULE
// -------------------------------------------------------------

model Class {
  id             String   @id @default(uuid()) @db.Uuid
  studioId       String   @map("studio_id") @db.Uuid
  title          String
  instructorId   String?  @map("instructor_id") @db.Uuid
  capacity       Int
  startTime      DateTime @map("start_time")
  endTime        DateTime @map("end_time")
  recurrenceRule String?  @map("recurrence_rule") // iCal RRULE string, e.g. "FREQ=WEEKLY;BYDAY=MO,WE"
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  studio     Studio    @relation(fields: [studioId], references: [id], onDelete: Cascade)
  instructor User?     @relation("Instructor", fields: [instructorId], references: [id])
  bookings   Booking[]

  @@index([studioId])
  @@index([studioId, startTime])
  @@map("classes")
}

// -------------------------------------------------------------
// BOOKINGS
// -------------------------------------------------------------

model Booking {
  id           String        @id @default(uuid()) @db.Uuid
  studioId     String        @map("studio_id") @db.Uuid
  classId      String        @map("class_id") @db.Uuid
  clientId     String        @map("client_id") @db.Uuid
  // Which membership this booking drew a credit from, if any (null
  // for monthly_unlimited, which never decrements anything). Storing
  // this — rather than re-deriving "the client's active membership"
  // at cancellation time — is what makes refunds exact even if a
  // client has switched memberships between booking and cancelling.
  membershipId String?       @map("membership_id") @db.Uuid
  status       BookingStatus @default(booked)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  studio     Studio      @relation(fields: [studioId], references: [id], onDelete: Cascade)
  class      Class       @relation(fields: [classId], references: [id], onDelete: Cascade)
  client     User        @relation("ClientBookings", fields: [clientId], references: [id])
  membership Membership? @relation(fields: [membershipId], references: [id])

  // Prevent the same client from double-booking the same class
  @@unique([classId, clientId])
  @@index([studioId])
  @@index([studioId, classId])
  @@map("bookings")
}

// -------------------------------------------------------------
// MEMBERSHIPS / PUNCH CARDS
// -------------------------------------------------------------

model Membership {
  id       String           @id @default(uuid()) @db.Uuid
  studioId String           @map("studio_id") @db.Uuid
  clientId String           @map("client_id") @db.Uuid
  type     MembershipType
  status   MembershipStatus @default(active)

  // --- punch_card fields ---
  totalPunches     Int? @map("total_punches") // fixed pool, never resets
  remainingPunches Int? @map("remaining_punches")

  // --- monthly_limited fields ---
  // e.g. "8 classes per month" -> classesPerPeriod = 8. Resets to
  // this value at the start of each period (see resetClassesUsed()
  // in src/lib/memberships.ts, intended to run on a schedule).
  classesPerPeriod Int? @map("classes_per_period")
  classesUsedThisPeriod Int @default(0) @map("classes_used_this_period")
  currentPeriodStart    DateTime? @map("current_period_start")

  // --- monthly_unlimited & monthly_limited: expiry ---
  expiresAt DateTime? @map("expires_at")

  // --- freeze tracking ---
  // When frozen, expiresAt should NOT advance. We record when the
  // freeze started so that on unfreeze we can push expiresAt forward
  // by exactly the frozen duration (see unfreezeMembership() in
  // src/lib/memberships.ts).
  frozenAt DateTime? @map("frozen_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  studio       Studio        @relation(fields: [studioId], references: [id], onDelete: Cascade)
  client       User          @relation("ClientMemberships", fields: [clientId], references: [id])
  bookings     Booking[]
  appointments Appointment[]

  @@index([studioId])
  @@index([studioId, clientId])
  @@map("memberships")
}

// =============================================================
// PHASE 2 — Service / Appointment / Instructor Availability
// =============================================================
// Same studioId-scoping pattern as Class/Booking — the auth
// middleware, tenant resolver, and getTenantDb() extension required
// ZERO changes to support these (just registered the new model names
// in TENANT_SCOPED_MODELS, see src/lib/db.ts).
// =============================================================

model Service {
  id          String  @id @default(uuid()) @db.Uuid
  studioId    String  @map("studio_id") @db.Uuid
  name        String
  durationMin Int     @map("duration_min")
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  studio       Studio        @relation(fields: [studioId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([studioId])
  @@map("services")
}

// -------------------------------------------------------------
// AVAILABILITY BLOCKS — recurring working hours per instructor
// -------------------------------------------------------------
// e.g. "Mondays 08:00-12:00" -> dayOfWeek=1, startMinute=480,
// endMinute=720. Appointments are only bookable inside a block that
// belongs to the chosen provider and doesn't already overlap another
// appointment for that provider (enforced in
// src/lib/appointments.ts, the same way createBooking() enforces
// class capacity).

model AvailabilityBlock {
  id          String @id @default(uuid()) @db.Uuid
  studioId    String @map("studio_id") @db.Uuid
  providerId  String @map("provider_id") @db.Uuid
  dayOfWeek   Int    @map("day_of_week") // 0 = Sunday ... 6 = Saturday
  startMinute Int    @map("start_minute") // minutes since midnight, e.g. 480 = 08:00
  endMinute   Int    @map("end_minute")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  studio   Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  provider User   @relation("ProviderAvailability", fields: [providerId], references: [id])

  @@index([studioId])
  @@index([studioId, providerId])
  @@map("availability_blocks")
}

// -------------------------------------------------------------
// APPOINTMENTS — 1-on-1, on-demand bookings against a provider's
// availability, distinct from the fixed-schedule group Class model.
// -------------------------------------------------------------

model Appointment {
  id           String            @id @default(uuid()) @db.Uuid
  studioId     String            @map("studio_id") @db.Uuid
  serviceId    String            @map("service_id") @db.Uuid
  providerId   String            @map("provider_id") @db.Uuid
  clientId     String            @map("client_id") @db.Uuid
  membershipId String?           @map("membership_id") @db.Uuid
  startTime    DateTime          @map("start_time")
  endTime      DateTime          @map("end_time")
  status       AppointmentStatus @default(booked)
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  studio     Studio      @relation(fields: [studioId], references: [id], onDelete: Cascade)
  service    Service     @relation(fields: [serviceId], references: [id])
  provider   User        @relation("AppointmentProvider", fields: [providerId], references: [id])
  client     User        @relation("AppointmentClient", fields: [clientId], references: [id])
  membership Membership? @relation(fields: [membershipId], references: [id])

  @@index([studioId])
  @@index([studioId, providerId, startTime])
  @@map("appointments")
}

// =============================================================
// LEADS MODULE
// =============================================================
// Mirrors what the screenshots showed: a "lead sources" picklist
// (Website, Facebook, Instagram, WhatsApp, Friend/Family,
// Commercial), a lead pipeline with a small fixed set of stages
// (LeadStatus above), follow-up tasks with due dates, and a
// "lost reason" picklist studios can customize themselves
// (mirrors the long custom list of reasons seen in the Arbox
// screenshots — "too expensive," "didn't like," "moved away," etc).
//
// A Lead is intentionally NOT a User row with role=lead — leads
// don't have a Supabase Auth account (they haven't signed up for
// anything yet), so they live in their own table. When a lead
// converts, convertedUserId links to the User row created for them
// at that point; the Lead row itself is kept for history/reporting
// rather than deleted.

model LeadSource {
  id        String   @id @default(uuid()) @db.Uuid
  studioId  String   @map("studio_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  leads  Lead[]

  @@unique([studioId, name])
  @@index([studioId])
  @@map("lead_sources")
}

// Studio-customizable reasons a lead didn't convert. This is
// deliberately its OWN picklist, separate from any future
// membership-cancellation or membership-freeze reason lists — the
// screenshots showed Arbox keeping these as independently-editable
// lists even though they serve a similar "why" purpose at different
// points in the client lifecycle. (Membership cancel/freeze reasons
// are not part of this layer; see the Memberships/Billing layer.)
model LeadLostReason {
  id        String   @id @default(uuid()) @db.Uuid
  studioId  String   @map("studio_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  studio Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  leads  Lead[]

  @@unique([studioId, name])
  @@index([studioId])
  @@map("lead_lost_reasons")
}

model Lead {
  id               String      @id @default(uuid()) @db.Uuid
  studioId         String      @map("studio_id") @db.Uuid
  fullName         String      @map("full_name")
  phone            String?
  email            String?
  sourceId         String?     @map("source_id") @db.Uuid
  status           LeadStatus  @default(new)
  assignedToId     String?     @map("assigned_to_id") @db.Uuid // staff member working this lead
  lostReasonId     String?     @map("lost_reason_id") @db.Uuid
  notes            String?
  // Set when status transitions to `converted` — the new User row
  // created for them. Kept separate from deleting/repurposing the
  // Lead row so conversion history/reporting survives intact.
  convertedUserId  String?     @map("converted_user_id") @db.Uuid
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  studio        Studio          @relation(fields: [studioId], references: [id], onDelete: Cascade)
  source        LeadSource?     @relation(fields: [sourceId], references: [id])
  assignedTo    User?           @relation("LeadAssignee", fields: [assignedToId], references: [id])
  lostReason    LeadLostReason? @relation(fields: [lostReasonId], references: [id])
  convertedUser User?           @relation("LeadConvertedUser", fields: [convertedUserId], references: [id])
  tasks         LeadTask[]

  @@index([studioId])
  @@index([studioId, status])
  @@map("leads")
}

model LeadTask {
  id           String       @id @default(uuid()) @db.Uuid
  studioId     String       @map("studio_id") @db.Uuid
  leadId       String       @map("lead_id") @db.Uuid
  assignedToId String?      @map("assigned_to_id") @db.Uuid
  type         LeadTaskType @default(follow_up)
  description  String?
  dueAt        DateTime     @map("due_at")
  completedAt  DateTime?    @map("completed_at")
  createdAt    DateTime     @default(now()) @map("created_at")

  studio     Studio @relation(fields: [studioId], references: [id], onDelete: Cascade)
  lead       Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedTo User?  @relation("LeadTaskAssignee", fields: [assignedToId], references: [id])

  @@index([studioId])
  @@index([studioId, dueAt])
  @@map("lead_tasks")
}
